            { id: 41, name: 'Stick War Legacy', cat: 'Strategy', emoji: '⚔️', embed: 'https://www.onlinegames.io/games/2022/unity/stick-war-legacy/index.html', rating: 4.7 },
            { id: 42, name: 'Survivor.io', cat: 'Strategy', emoji: '🧟', embed: 'https://www.onlinegames.io/games/2022/unity/survivor-io/index.html', rating: 4.6 },
            { id: 43, name: 'Element Blocks', cat: 'Strategy', emoji: '🧩', embed: 'https://www.onlinegames.io/games/2022/unity/element-blocks/index.html', rating: 4.4 },
        ];

        let currentFilter = 'all';
        let currentGame = null;

        // ===== RENDER GAMES =====
        function getStars(rating) {
            return '★'.repeat(Math.floor(rating)) + (rating % 1 >= 0.5 ? '½' : '');
        }

        function renderGames(filter = 'all', search = '') {
            const grid = document.getElementById('gamesGrid');
            const count = document.getElementById('gameCount');
            const title = document.getElementById('sectionTitle');

            let filtered = [...GAMES];

            if (filter === 'popular') {
                filtered.sort((a, b) => b.rating - a.rating);
                title.textContent = '🔥 Popular Games';
            } else if (filter !== 'all') {
                filtered = filtered.filter(g => g.cat === filter);
                title.textContent = `🎮 ${filter} Games`;
            } else {
                title.textContent = '🎮 All Games';
            }

            if (search) {
                const s = search.toLowerCase();
                filtered = filtered.filter(g => g.name.toLowerCase().includes(s));
                title.textContent = `🔍 Results for "${search}"`;
            }

            count.textContent = `${filtered.length} game${filtered.length !== 1 ? 's' : ''}`;

            if (filtered.length === 0) {
                grid.innerHTML = `
                    <div class="no-results">
                        <div class="icon">🔍</div>
                        <h3>No games found</h3>
                        <p>Try a different search or category</p>
                    </div>
                `;
                return;
            }

            grid.innerHTML = filtered.map(game => `
                <div class="game-card" onclick="openGame(${game.id})">
                    <div class="thumb">
                        ${game.emoji}
                        <div class="play-overlay">
                            <div class="play-btn-icon">▶</div>
                        </div>
                    </div>
                    <div class="info">
                        <h3>${game.name}</h3>
                        <div class="meta">
                            <span class="category-tag">${game.cat}</span>
                            <span class="rating">${getStars(game.rating)}</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // ===== FILTER & SEARCH =====
        function filterGames(cat) {
            currentFilter = cat;
            document.querySelectorAll('.category-chip').forEach(c => {
                c.classList.toggle('active', c.dataset.cat === cat);
            });
            const search = document.getElementById('searchInput').value;
            renderGames(cat, search);
        }

        function searchGames(query) {
            renderGames(currentFilter, query);
        }

        // ===== GAME MODAL =====
        function openGame(id) {
            const game = GAMES.find(g => g.id === id);
            if (!game) return;

            currentGame = game;
            document.getElementById('modalTitle').textContent = `${game.emoji} ${game.name}`;
            document.getElementById('gameModal').classList.add('open');
            document.body.style.overflow = 'hidden';

            const frame = document.getElementById('gameFrame');
            const spinner = document.getElementById('modalSpinner');

            frame.style.display = 'none';
            spinner.style.display = 'flex';

            frame.onload = () => {
                spinner.style.display = 'none';
                frame.style.display = 'block';
            };

            frame.src = game.embed;
        }

        function closeGame() {
            document.getElementById('gameModal').classList.remove('open');
            document.body.style.overflow = '';
            const frame = document.getElementById('gameFrame');
            frame.src = '';
            frame.style.display = 'none';
        }

        document.getElementById('gameModal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('gameModal')) closeGame();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeGame();
        });

        // ===== MOBILE MENU =====
        function toggleMobileMenu() {
            document.getElementById('mobileMenu').classList.toggle('open');
        }

        function closeMobileMenu() {
            document.getElementById('mobileMenu').classList.remove('open');
        }

        // ===== NAVBAR SCROLL EFFECT =====
        window.addEventListener('scroll', () => {
            const navbar = document.getElementById('navbar');
            navbar.classList.toggle('navbar-scrolled', window.scrollY > 20);
        });

        // ===== INIT =====
        renderGames('all');
    </script>
</body>
</html>
